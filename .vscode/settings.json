{
  "editor.formatOnSave": true,
  "files.insertFinalNewline": true,
  "[templ]": {
    "editor.defaultFormatter": "a-h.templ"
  },
  "emmet.includeLanguages": {
    "templ": "html"
  },
  "go.lintTool": "golangci-lint",
  "go.lintFlags": [
    "--path-mode=abs"
  ],
  "go.formatTool": "custom",
  "go.alternateTools": {
    "customFormatter": "golangci-lint"
  },
  "go.formatFlags": [
    "fmt",
    "--stdin"
  ]
}
